{
	"name": "pi-agent-suite",
	"version": "0.1.4",
	"description": "Adds a configurable multi-agent layer to pi, with context management, Codex quota status, a custom footer, and more.",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi",
		"pi-agent",
		"multi-agent"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/n-r-w/pi-agent-suite"
	},
	"bugs": {
		"url": "https://github.com/n-r-w/pi-agent-suite/issues"
	},
	"homepage": "https://github.com/n-r-w/pi-agent-suite#readme",
	"files": [
		"extensions",
		"shared",
		"README.md",
		"package.json"
	],
	"pi": {
		"extensions": [
			"./extensions/footer/index.ts",
			"./extensions/codex-verbosity/index.ts",
			"./extensions/codex-quota/index.ts",
			"./extensions/custom-compaction/index.ts",
			"./extensions/context-projection/index.ts",
			"./extensions/context-overflow/index.ts",
			"./extensions/main-agent-selection/index.ts",
			"./extensions/run-subagent/index.ts",
			"./extensions/consult-advisor/index.ts"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-agent-core": "*",
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"typebox": "*"
	}
}
